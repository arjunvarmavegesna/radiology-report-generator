# Copy to .env.local and fill in. NEVER commit .env.local.

# --- Firebase client (safe to expose to the browser) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin (server only — used by scripts/set-role.ts and Phase 2
#     server actions). Alternatively place a serviceAccountKey.json at the
#     project root. Escape newlines in the private key as \n. ---
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# --- AI provider ---
# Which model drafts reports. Optional. If unset, the dispatcher prefers
# Claude when ANTHROPIC_API_KEY is present, else Gemini.
# Values: "claude" | "gemini"
AI_PROVIDER=

# Anthropic Claude (paid; no free tier; ~$0.03/case with prompt caching)
ANTHROPIC_API_KEY=

# Google Gemini (free tier covers this clinic's volume)
GEMINI_API_KEY=

# Gemini model. Defaults to gemini-2.5-flash (generous free tier).
# gemini-2.5-pro requires billing enabled on the GCP project.
GEMINI_MODEL=

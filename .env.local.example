# Copy to .env.local and fill in. NEVER commit .env.local.

# --- Firebase client (safe to expose to the browser) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin (server only — used by scripts/set-role.ts and, later,
#     server actions). Alternatively place a serviceAccountKey.json at the
#     project root. Escape newlines in the private key as \n. ---
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# --- Anthropic (Phase 2 — not used yet) ---
ANTHROPIC_API_KEY=

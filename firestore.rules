rules_version = '2';

// Deploy with: firebase deploy --only firestore:rules
//
// Single-role workspace: every signed-in user can capture cases, review
// drafts, and approve. The three legacy roles (radiologist / typist /
// reviewer) still exist as Firebase custom claims for back-compat, but
// they're no longer enforced here — auth is the only gate.
//
// Server-side writes (`/api/generate`, `/api/export`) use the Firebase
// Admin SDK and bypass these rules entirely.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // User profiles. Provisioned by an admin / the set-role script —
    // never written from the client.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // AI Learning store: corrections + approved examples fed back into prompts.
    // Any signed-in user may add entries and clear them; entries are immutable
    // once written (no updates). Server reads use the Admin SDK and bypass this.
    match /learning/{entryId} {
      allow read, create, delete: if isSignedIn();
      allow update: if false;
    }

    match /cases/{caseId} {
      // Creation: any signed-in user. Require the doc to claim them as
      // the radiologist (so cases are attributed) and start at the
      // initial status (so a client can't skip the pipeline by
      // creating already-approved cases).
      allow create: if isSignedIn()
        && request.resource.data.radiologistId == request.auth.uid
        && request.resource.data.status == 'pending_typing';

      allow read: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if false;

      // Append-only audit log under each case.
      match /auditLog/{logId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if false;
      }
    }
  }
}
